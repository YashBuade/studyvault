# Database Configuration
# For local MySQL: mysql://root:password@localhost:3306/studyvault_db
# For MariaDB: mysql://user:password@host:3306/studyvault_db
# For production, set via environment variable in your hosting platform
DATABASE_URL="postgresql://postgres.npxwflwxpoijjpzumsqt:KatEJq5D5fXwy5Mm@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres"

# Authentication
AUTH_SECRET="your-auth-secret-key-generate-a-random-string-here"

# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add redirect URI: http://localhost:3000/api/auth/google/callback
# 5. Copy Client ID and Client Secret below
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
# Optional: force fixed redirect URI (useful in production/proxy setups)
# GOOGLE_OAUTH_REDIRECT_URI="https://yourdomain.com/api/auth/google/callback"
# Optional: comma-separated allowlist used to resolve forwarded origins safely
# GOOGLE_OAUTH_ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Admin Security
# Comma-separated emails allowed to use admin portal login
ADMIN_EMAIL_ALLOWLIST="admin@example.com"
# One-time bootstrap secret used by `npm run admin:create`
ADMIN_BOOTSTRAP_KEY="set-a-long-random-bootstrap-secret"

# Supabase Storage (required for file upload/download on serverless hosts)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"
SUPABASE_STORAGE_BUCKET="studyvault-files"
FILE_UPLOAD_MAX_MB="4"
NEXT_PUBLIC_FILE_UPLOAD_MAX_MB="4"

# Email Configuration (optional, for future features)
# SENDGRID_API_KEY=your_sendgrid_api_key
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=your_ga_tracking_id

# Feature Flags (optional)
# NEXT_PUBLIC_ENABLE_SHARING=true
# NEXT_PUBLIC_ENABLE_COMMENTS=true
# NEXT_PUBLIC_ENABLE_COLLABORATION=true
